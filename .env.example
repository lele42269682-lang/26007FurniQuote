# FurniQuote AI · 环境变量模板
# 用法：复制为 .env 并填入真实值，或将值存入 macOS Keychain 后由 start.sh 注入
# ⚠️ 此文件可上传 GitHub，但 .env 绝对不能上传

# ===== AI · 视觉与文本 =====
DASHSCOPE_API_KEY=your_bailian_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# ===== AI · 3D 与材质 =====
HUNYUAN3D_API_KEY=your_hunyuan_key_here
SEEDREAM_API_KEY=your_seedream_key_here

# ===== 钉钉集成 =====
DINGTALK_APP_KEY=your_dingtalk_app_key
DINGTALK_APP_SECRET=your_dingtalk_app_secret

# ===== 数据库与缓存 =====
DATABASE_URL=sqlite:///./data/furniquote.db
REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIR=./chroma_db

# ===== 应用配置 =====
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
